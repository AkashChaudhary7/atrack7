rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // IsSignedIn global gate
    function isSignedIn() {
      return request.auth != null;
    }

    // Owner validation helper
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users namespace matching partitions
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /expenses/{expenseId} {
        allow read, write: if isOwner(userId);
      }

      match /assetAccounts/{accountId} {
        allow read, write: if isOwner(userId);
      }

      match /bills/{billId} {
        allow read, write: if isOwner(userId);
      }

      match /habits/{habitId} {
        allow read, write: if isOwner(userId);
      }

      match /intimacyLogs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /jerkOffLogs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /medicines/{medicineId} {
        allow read, write: if isOwner(userId);
      }

      match /weightRecords/{recordId} {
        allow read, write: if isOwner(userId);
      }

      match /workouts/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }

      match /studySessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      match /passwords/{passwordId} {
        allow read, write: if isOwner(userId);
      }

      match /documents/{documentId} {
        allow read, write: if isOwner(userId);
      }

      match /personalIDs/{idRecordId} {
        allow read, write: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
