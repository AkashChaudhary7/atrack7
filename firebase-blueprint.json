{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about the authenticated user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique user ID" },
        "email": { "type": "string", "description": "The email address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "currentProfile": { "type": "string", "description": "The active sub-profile name" }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Personal expense entries for a profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "assetAccountId": { "type": "string", "description": "Deducted asset account ID" }
      },
      "required": ["id", "userId", "profileId", "amount", "category", "description", "date"]
    },
    "AssetAccount": {
      "title": "AssetAccount",
      "description": "A single asset account containing balance and details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["liquid", "fixed"] },
        "category": { "type": "string", "enum": ["Savings Account", "Cash", "Stocks", "Mutual Fund", "Fixed Deposit", "Bonds", "Loan Given", "Other"] },
        "balance": { "type": "number" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "userId", "profileId", "name", "type", "category", "balance", "updatedAt"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Bills and EMIs trackers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "dueDate": { "type": "string" },
        "category": { "type": "string" },
        "isPaid": { "type": "boolean" },
        "reminderDays": { "type": "number" }
      },
      "required": ["id", "userId", "profileId", "title", "amount", "dueDate", "category", "isPaid", "reminderDays"]
    },
    "Habit": {
      "title": "Habit",
      "description": "Good habits checklist and streak tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "name": { "type": "string" },
        "completedDates": { "type": "array" },
        "createdAt": { "type": "string" },
        "streak": { "type": "number" }
      },
      "required": ["id", "userId", "profileId", "name", "completedDates", "createdAt", "streak"]
    },
    "IntimacyLog": {
      "title": "IntimacyLog",
      "description": "Confidential intimacy checkpoints",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "partnerName": { "type": "string" },
        "date": { "type": "string" },
        "mood": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "profileId", "partnerName", "date", "mood"]
    },
    "JerkOffLog": {
      "title": "JerkOffLog",
      "description": "Retention frequency logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "date": { "type": "string" },
        "count": { "type": "number" },
        "sessions": { "type": "number" }
      },
      "required": ["id", "userId", "profileId", "date", "count", "sessions"]
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Medicine item prescriptions and histories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "name": { "type": "string" },
        "dosageDaily": { "type": "number" },
        "totalPillsLeft": { "type": "number" },
        "reminderTime": { "type": "string" },
        "history": { "type": "object" }
      },
      "required": ["id", "userId", "profileId", "name", "dosageDaily", "totalPillsLeft", "reminderTime", "history"]
    },
    "WeightRecord": {
      "title": "WeightRecord",
      "description": "Fitness weight measurement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "date": { "type": "string" },
        "weight": { "type": "number" }
      },
      "required": ["id", "userId", "profileId", "date", "weight"]
    },
    "WorkoutLog": {
      "title": "WorkoutLog",
      "description": "Workout details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "type": { "type": "string" },
        "reps": { "type": "number" },
        "sets": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["id", "userId", "profileId", "type", "reps", "sets", "date"]
    },
    "PlannerTask": {
      "title": "PlannerTask",
      "description": "Tasks scheduled in the study planner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "type": { "type": "string" }
      },
      "required": ["id", "userId", "profileId", "title", "date", "isCompleted", "type"]
    },
    "StudyFocusSession": {
      "title": "StudyFocusSession",
      "description": "Interactive deep study focus sprints",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "date": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "subject": { "type": "string" }
      },
      "required": ["id", "userId", "profileId", "date", "durationMinutes", "subject"]
    },
    "SecurePassword": {
      "title": "SecurePassword",
      "description": "Secure passwords and secret keys under safe vault",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "title": { "type": "string" },
        "username": { "type": "string" },
        "passwordEncrypted": { "type": "string" },
        "category": { "type": "string" },
        "url": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "profileId", "title", "username", "passwordEncrypted", "category"]
    },
    "SecureDocument": {
      "title": "SecureDocument",
      "description": "End-to-end client-side encrypted document and photo storage files",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "title": { "type": "string" },
        "fileName": { "type": "string" },
        "uploadedAt": { "type": "string" },
        "fileDataEncrypted": { "type": "string" }
      },
      "required": ["id", "userId", "profileId", "title", "fileName", "uploadedAt", "fileDataEncrypted"]
    },
    "PersonalID": {
      "title": "PersonalID",
      "description": "Secure storage of official reference ID credentials info",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "idType": { "type": "string" },
        "idNumber": { "type": "string" },
        "nameOnID": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "profileId", "idType", "idNumber", "nameOnID"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Milestones and targets tracker for long-term objectives",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "profileId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Financial", "Skill Mastery", "Other"] },
        "targetValue": { "type": "number" },
        "currentValue": { "type": "number" },
        "unit": { "type": "string" },
        "targetDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "milestones": { "type": "array" }
      },
      "required": ["id", "userId", "profileId", "title", "category", "targetValue", "currentValue", "unit", "targetDate", "createdAt", "updatedAt", "milestones"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Root user profiles"
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Subcollection of expenses for the user"
    },
    "/users/{userId}/assetAccounts/{accountId}": {
      "schema": "AssetAccount",
      "description": "Subcollection of asset accounts tracking balances"
    },
    "/users/{userId}/bills/{billId}": {
      "schema": "Bill",
      "description": "Subcollection of bills and EMIs"
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "Subcollection of user habits and completions"
    },
    "/users/{userId}/intimacyLogs/{logId}": {
      "schema": "IntimacyLog",
      "description": "Subcollection of private intimacy parameters"
    },
    "/users/{userId}/jerkOffLogs/{logId}": {
      "schema": "JerkOffLog",
      "description": "Subcollection of semen retention checks"
    },
    "/users/{userId}/medicines/{medicineId}": {
      "schema": "Medicine",
      "description": "Subcollection of medicines and history tracking states"
    },
    "/users/{userId}/weightRecords/{recordId}": {
      "schema": "WeightRecord",
      "description": "Subcollection of weight tracking measurements"
    },
    "/users/{userId}/workouts/{logId}": {
      "schema": "WorkoutLog",
      "description": "Subcollection of workout reps and sets"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "PlannerTask",
      "description": "Subcollection of daily study and personal tasks"
    },
    "/users/{userId}/studySessions/{sessionId}": {
      "schema": "StudyFocusSession",
      "description": "Subcollection of deep study logged minutes status"
    },
    "/users/{userId}/passwords/{passwordId}": {
      "schema": "SecurePassword",
      "description": "Subcollection of safe vault accounts and credentials"
    },
    "/users/{userId}/documents/{documentId}": {
      "schema": "SecureDocument",
      "description": "Subcollection of safe vault uploaded scanned documents base64 data"
    },
    "/users/{userId}/personalIDs/{idRecordId}": {
      "schema": "PersonalID",
      "description": "Subcollection of user ID cards profiles"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "Subcollection of user long-term goals and milestones tracking"
    }
  }
}
